# -------------------------------------------------------
# 可以直接把 UCL_RAG 的 .env 複製過來，再做以下兩處修改：
#   1. POSTGRES_DSN  → 把 ucl_rag 改成 ucl_kag，port 改 5433
#   2. 新增 KAG_PROJECT_ID=1
# Neo4j 相關那幾行留著沒關係，config 會自動忽略。
# -------------------------------------------------------

# OpenAI-compatible provider (b225.54ucl.com)
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=nemotron-3-super-120b
OPENAI_PLANNER_MODEL=qwen3-coder-next
OPENAI_EMBEDDING_MODEL=qwen3-embedding-8b
OPENAI_EMBEDDING_DIMENSIONS=4096

# PostgreSQL + pgvector
# 注意：port 5433（避免與 UCL_RAG 的 5432 衝突），database 名稱 ucl_kag
POSTGRES_DSN=postgresql://postgres:postgres@postgres:5433/ucl_kag
PGVECTOR_TABLE=document_chunks

# KAG / OpenSPG（UCL_RAG 沒有，需要手動新增）
KAG_PROJECT_ID=1
KAG_CONFIG_PATH=/app/kag_config.yaml

# Google Drive（與 UCL_RAG 相同，直接複製）
GOOGLE_SERVICE_ACCOUNT_JSON=/app/secrets/google-service-account.json
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.readonly
GDRIVE_FOLDER_ID=

# RAG tuning
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
RETRIEVAL_TOP_K=6
SYNC_INTERVAL_HOURS=6

# CORS
CORS_ALLOW_ORIGINS=*
